@model List<DriveNow.Models.Locacao>
@{
    ViewBag.Title = "Locacoes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="barra-acoes">
    <h2>Historico de Locacoes</h2>
    <a href="/Locacoes/Nova" class="btn btn-primario">+ Nova Locacao</a>
</div>

<div class="tabela-wrap">
    @if (Model.Count == 0)
    {
        <p class="sem-dados">Nenhuma locacao registrada ainda.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Cliente</th>
                    <th>Veiculo</th>
                    <th>Placa</th>
                    <th>Retirada</th>
                    <th>Devolucao</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Acoes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    string badgeClass = "badge-amarelo";
                    if (l.Status == "Concluida") badgeClass = "badge-verde";
                    if (l.Status == "Cancelada") badgeClass = "badge-vermelho";

                    <tr>
                        <td>@l.IdLocacao</td>
                        <td>@l.NomeCliente</td>
                        <td>@l.NomeVeiculo</td>
                        <td><code>@l.PlacaVeiculo</code></td>
                        <td>@l.DataRetirada.ToString("dd/MM/yyyy")</td>
                        <td>@l.DataDevolucao.ToString("dd/MM/yyyy")</td>
                        <td>R$ @l.ValorTotal.ToString("N2")</td>
                        <td><span class="badge @badgeClass">@l.Status</span></td>
                        <td>
                            @if (l.Status == "Ativa")
                            {
                                <a href="/Locacoes/Concluir/@l.IdLocacao"
                                   class="btn btn-sucesso"
                                   onclick="return confirm('Confirmar devolucao do veiculo?')">
                                    Concluir
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
