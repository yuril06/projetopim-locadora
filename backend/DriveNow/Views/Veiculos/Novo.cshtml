@model DriveNow.Models.Veiculo
@{
    ViewBag.Title = "Novo Veiculo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (ViewBag.Erro != null)
{
    <div class="alerta erro" style="margin:20px 30px 0;">&#9888; @ViewBag.Erro</div>
}

<div class="form-wrap">
    @using (Html.BeginForm("Novo", "Veiculos", FormMethod.Post))
    {
        <div class="form-linha">
            <div class="form-grupo">
                <label>Marca *</label>
                @Html.TextBoxFor(m => m.Marca, new { @class = "form-control", placeholder = "Ex: Volkswagen" })
            </div>
            <div class="form-grupo">
                <label>Modelo *</label>
                @Html.TextBoxFor(m => m.Modelo, new { @class = "form-control", placeholder = "Ex: Gol" })
            </div>
        </div>

        <div class="form-linha">
            <div class="form-grupo">
                <label>Ano</label>
                @Html.TextBoxFor(m => m.Ano, new { @class = "form-control", placeholder = "2023", type = "number", min = "1990", max = "2030" })
            </div>
            <div class="form-grupo">
                <label>Placa *</label>
                @Html.TextBoxFor(m => m.Placa, new { @class = "form-control", placeholder = "ABC1D23", maxlength = "8" })
            </div>
        </div>

        <div class="form-linha">
            <div class="form-grupo">
                <label>Cor</label>
                @Html.TextBoxFor(m => m.Cor, new { @class = "form-control", placeholder = "Branco" })
            </div>
            <div class="form-grupo">
                <label>Categoria</label>
                @Html.DropDownListFor(
                    m => m.Categoria,
                    new SelectList(new[] { "Basico", "Intermediario", "SUV", "Luxo" }),
                    new { @class = "form-control" }
                )
            </div>
        </div>

        <div class="form-grupo">
            <label>Valor da Diaria (R$) *</label>
            @Html.TextBoxFor(m => m.ValorDiaria, new {
                @class      = "form-control",
                placeholder = "Ex: 99.90",
                type        = "number",
                step        = "0.01",
                min         = "0"
            })
        </div>

        <div class="form-botoes">
            <button type="submit" class="btn btn-primario">Cadastrar Veiculo</button>
            <a href="/Veiculos/Index" class="btn btn-secundario">Cancelar</a>
        </div>
    }
</div>
