@model List<DriveNow.Models.Veiculo>
@{
    ViewBag.Title = "Veiculos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="barra-acoes">
    <h2>Frota de Veiculos</h2>
    <a href="/Veiculos/Novo" class="btn btn-primario">+ Novo Veiculo</a>
</div>

<div class="tabela-wrap">
    @if (Model.Count == 0)
    {
        <p class="sem-dados">Nenhum veiculo cadastrado.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Veiculo</th>
                    <th>Ano</th>
                    <th>Placa</th>
                    <th>Cor</th>
                    <th>Categoria</th>
                    <th>Diaria</th>
                    <th>Status</th>
                    <th>Acoes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    <tr>
                        <td>@v.IdVeiculo</td>
                        <td><strong>@v.Marca @v.Modelo</strong></td>
                        <td>@(v.Ano > 0 ? v.Ano.ToString() : "-")</td>
                        <td><code>@v.Placa</code></td>
                        <td>@v.Cor</td>
                        <td>@v.Categoria</td>
                        <td>R$ @v.ValorDiaria.ToString("N2")</td>
                        <td>
                            @if (v.Disponivel)
                            {
                                <span class="badge badge-verde">Disponivel</span>
                            }
                            else
                            {
                                <span class="badge badge-vermelho">Alugado</span>
                            }
                        </td>
                        <td>
                            @if (v.Disponivel)
                            {
                                <a href="/Veiculos/AlterarDisponibilidade/@v.IdVeiculo?disponivel=false"
                                   class="btn btn-perigo"
                                   onclick="return confirm('Marcar como alugado?')">
                                    Marcar Alugado
                                </a>
                            }
                            else
                            {
                                <a href="/Veiculos/AlterarDisponibilidade/@v.IdVeiculo?disponivel=true"
                                   class="btn btn-sucesso">
                                    Liberar
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
